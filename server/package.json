{
  "name": "task-manager-server",
  "version": "1.0.0",
  "description": "Team Task Manager Backend API",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "npx prisma migrate deploy && node dist/prisma/seed.js && node dist/src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0"
  }
}
